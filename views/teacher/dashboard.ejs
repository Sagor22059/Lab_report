<%- include('../partials/header', { title: 'Teacher Dashboard' }) %>
<h2>Teacher Dashboard</h2>
<a href="/teacher/create-assignment" class="btn btn-success mb-3">+ Create Assignment</a>
<table class="table">
    <thead><tr><th>Assignment</th><th>Course</th><th>Deadline</th><th>Submissions</th><th>Action</th></tr></thead>
    <tbody>
        <% assignments.forEach(ass => { %>
            <tr>
                <td><%= ass.title %></td>
                <td><%= ass.course_name %></td>
                <td><%= new Date(ass.deadline).toLocaleString() %></td>
                <td><%= ass.submission_count %></td>
                <td><a href="/teacher/submissions/<%= ass.id %>" class="btn btn-sm btn-primary">View Submissions</a></td>
            </tr>
        <% }) %>
    </tbody>
</table>
<%- include('../partials/footer') %>