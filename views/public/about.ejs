<%- include('../partials/header', { title: 'About' }) %>

<div class="container my-5">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <h1 class="mb-4">About Lab Report System</h1>
            
            <div class="card mb-4">
                <div class="card-body">
                    <h3 class="card-title">Our Mission</h3>
                    <p class="card-text">
                        To provide a modern, secure, and user-friendly platform that streamlines the lab report submission 
                        process for educational institutions, enabling seamless communication between students and instructors.
                    </p>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-body">
                    <h3 class="card-title">What We Offer</h3>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item">
                            <strong>📤 For Students:</strong> Easy-to-use platform to submit lab reports, track grades, 
                            and receive detailed feedback from instructors.
                        </li>
                        <li class="list-group-item">
                            <strong>✅ For Teachers:</strong> Efficient tools to manage assignments, review submissions, 
                            provide grades, and maintain detailed student records.
                        </li>
                        <li class="list-group-item">
                            <strong>⚙️ For Administrators:</strong> Complete system management capabilities including user 
                            management, course configuration, and system monitoring.
                        </li>
                    </ul>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-body">
                    <h3 class="card-title">Key Features</h3>
                    <div class="row">
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                <li>✨ Secure user authentication</li>
                                <li>📱 Responsive mobile-friendly design</li>
                                <li>🔐 Data encryption & privacy</li>
                                <li>📊 Real-time progress tracking</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                <li>💬 Feedback and commenting system</li>
                                <li>📈 Comprehensive reporting tools</li>
                                <li>⚡ Fast and reliable performance</li>
                                <li>🎓 Role-based access control</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <h3 class="card-title">Technology Stack</h3>
                    <p class="card-text mb-3">
                        Built with modern, reliable technologies:
                    </p>
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Backend</h6>
                            <ul class="small">
                                <li>Node.js with Express.js</li>
                                <li>MySQL Database</li>
                                <li>Bcrypt for security</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <h6>Frontend</h6>
                            <ul class="small">
                                <li>Bootstrap 5 Framework</li>
                                <li>EJS Templating</li>
                                <li>Responsive JavaScript</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <div class="alert alert-info mt-4">
                <h5 class="alert-heading">Get Started Today!</h5>
                <p class="mb-0">
                    Ready to use our platform? 
                    <a href="/register" class="alert-link">Create an account</a> or 
                    <a href="/login" class="alert-link">login</a> if you already have one.
